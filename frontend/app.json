{
  "expo": {
    "name": "UNIPRO HAWKER SYSTEM",
    "slug": "unipro-pos-new",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/unipro-hawker.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/unipro-hawker.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "experiments": {
      "turboModules": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.unipro.pos"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/unipro-hawker.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.unipro.pos",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/unipro-hawker.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "984fbd31-a0ce-4d4e-a9e4-09cf244c78e1"
      }
    },
    "owner": "abdulazmiuniprosg"
  }
}
